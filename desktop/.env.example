# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit real keys, tokens, or secrets to this repo — it is public.

# Optional: bring-your-own Anthropic API key (only needed if you don't use the
# Claude Code subscription provider).
# ANTHROPIC_API_KEY=

# Optional: override the local UE bridge port (defaults to 17645).
# MYIKA_BRIDGE_PORT=17645

# Auto-generated shared secret for the local WebSocket bridge.
# Leave empty here — the desktop app and UE plugin negotiate this at runtime
# via a per-user token file. Documented for awareness only.
# MYIKA_BRIDGE_TOKEN=
